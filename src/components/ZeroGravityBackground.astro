---
---
<div class="zero-gravity-container">
  <!-- Sutil cuadrícula CSS de fondo -->
  <div class="grid-overlay"></div>
  <!-- Lienzo para las partículas flotantes -->
  <canvas id="zero-gravity-canvas"></canvas>
</div>

<style>
  .zero-gravity-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    overflow: hidden;
    background-color: var(--color-neutral);
    pointer-events: none;
  }

  .grid-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* Cuadrícula sutil */
    background-image: 
      linear-gradient(rgba(60, 56, 54, 0.15) 1px, transparent 1px),
      linear-gradient(90deg, rgba(60, 56, 54, 0.15) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0.25;
  }
</style>

<script>
  // Clase que modela las partículas flotantes en gravedad cero
  class Particle {
    x: number;
    y: number;
    size: number;
    speedX: number;
    speedY: number;
    color: string;
    type: 'square' | 'cross' | 'dot';
    angle: number;
    spin: number;

    constructor(canvasWidth: number, canvasHeight: number) {
      this.x = Math.random() * canvasWidth;
      this.y = Math.random() * canvasHeight;
      this.size = Math.random() * 6 + 3; // Tamaño entre 3px y 9px
      this.speedX = (Math.random() - 0.5) * 0.3;
      this.speedY = -(Math.random() * 0.3 + 0.1); // Flotan lentamente hacia arriba
      
      // Colores de la paleta Gruvbox
      const colors = ['#fe8019', '#83a598', '#b8bb26', '#ebdbb2'];
      this.color = colors[Math.floor(Math.random() * colors.length)];
      
      // Tipo de partículas geométricas retro
      const types: ('square' | 'cross' | 'dot')[] = ['square', 'cross', 'dot'];
      this.type = types[Math.floor(Math.random() * types.length)];
      
      this.angle = Math.random() * Math.PI * 2;
      this.spin = (Math.random() - 0.5) * 0.008; // Rotación lenta
    }

    update(canvasWidth: number, canvasHeight: number, mouseX: number, mouseY: number) {
      this.x += this.speedX;
      this.y += this.speedY;
      this.angle += this.spin;

      // Reaparecer en la parte inferior si se salen de la pantalla
      if (this.y < -15) {
        this.y = canvasHeight + 15;
        this.x = Math.random() * canvasWidth;
      }
      if (this.x < -15) this.x = canvasWidth + 15;
      if (this.x > canvasWidth + 15) this.x = -15;

      // Interacción con el cursor (repulsión suave)
      const dx = mouseX - this.x;
      const dy = mouseY - this.y;
      const distance = Math.sqrt(dx * dx + dy * dy);
      
      if (distance < 120) {
        const force = (120 - distance) / 120;
        const angle = Math.atan2(dy, dx);
        this.x -= Math.cos(angle) * force * 1.5;
        this.y -= Math.sin(angle) * force * 1.5;
      }
    }

    draw(ctx: CanvasRenderingContext2D) {
      ctx.save();
      ctx.translate(this.x, this.y);
      ctx.rotate(this.angle);
      ctx.fillStyle = this.color;
      ctx.strokeStyle = this.color;
      ctx.lineWidth = 1.5;

      if (this.type === 'square') {
        // Cuadrado
        ctx.fillRect(-this.size / 2, -this.size / 2, this.size, this.size);
      } else if (this.type === 'cross') {
        // Cruz técnica (+)
        ctx.beginPath();
        ctx.moveTo(-this.size / 2, 0);
        ctx.lineTo(this.size / 2, 0);
        ctx.moveTo(0, -this.size / 2);
        ctx.lineTo(0, this.size / 2);
        ctx.stroke();
      } else {
        // Punto sutil
        ctx.beginPath();
        ctx.arc(0, 0, this.size / 3, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.restore();
    }
  }

  function initBackground() {
    const canvas = document.getElementById('zero-gravity-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Respetar la preferencia de movimiento reducido del usuario
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      canvas.style.display = 'none';
      return;
    }

    let canvasWidth = canvas.clientWidth;
    let canvasHeight = canvas.clientHeight;
    
    function resizeCanvas() {
      canvasWidth = window.innerWidth;
      canvasHeight = window.innerHeight;
      canvas.width = canvasWidth;
      canvas.height = canvasHeight;
    }
    
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    // Ajustar número de partículas según el tamaño de la pantalla
    const numParticles = Math.min(75, Math.floor((canvasWidth * canvasHeight) / 20000));
    const particles: Particle[] = [];
    for (let i = 0; i < numParticles; i++) {
      particles.push(new Particle(canvasWidth, canvasHeight));
    }

    // Coordenadas del cursor
    let mouseX = -1000;
    let mouseY = -1000;
    
    window.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    window.addEventListener('mouseleave', () => {
      mouseX = -1000;
      mouseY = -1000;
    });

    // Bucle de animación
    function animate() {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvasWidth, canvasHeight);

      particles.forEach((particle) => {
        particle.update(canvasWidth, canvasHeight, mouseX, mouseY);
        particle.draw(ctx);
      });

      requestAnimationFrame(animate);
    }

    animate();
  }

  // Inicializar en carga y compatibilidad con transiciones de Astro
  initBackground();
  document.addEventListener('astro:page-load', initBackground);
</script>
